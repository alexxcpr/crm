generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  date_created DateTime  @default(now())
  date_updated DateTime  @updatedAt

  email        String    @unique
  hash         String

  first_name   String?
  last_name    String?

  roles UserRole[]

  @@map("user")
}

