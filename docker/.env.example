DOMAIN_BASE=stanciulescu.xyz
TENANT_HOST_REGEXP=^.+\.stanciulescu\.xyz$
ACME_EMAIL=admin@stanciulescu.xyz
CF_DNS_API_TOKEN=change-me

JWT_SECRET=change-me-use-a-long-random-secret

DB_USER=base_user
DB_PASSWORD=change-me
DB_ADMIN_USER=base_user
DB_ADMIN_PASSWORD=change-me
DEFAULT_TENANT_SLUG=dev
DEFAULT_TENANT_DB=devdb
META_DB=meta
N8N_DB=n8n_db
PROVISIONING_INTERNAL_SECRET=change-me-use-a-long-random-secret

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=

NUXT_PUBLIC_API_BASE=/api
NUXT_API_BASE_INTERNAL=http://backend:4000/api
NUXT_AUTH_SECURE_COOKIE=true
NUXT_AUTH_HTTP_ONLY=true

N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_ENCRYPTION_KEY=change-me-use-32-plus-random-chars
N8N_API_KEY=
N8N_WEBHOOK_SECRET=

# Production: HTTPS + Let's Encrypt via Cloudflare
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_TLS=true
TRAEFIK_CERT_RESOLVER=cloudflare
